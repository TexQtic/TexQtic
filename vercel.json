{
  "version": 2,
  "buildCommand": "npm install && cd server && npm install && cd .. && npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/dpp/v1/context\\.jsonld",
      "headers": {
        "Content-Type": "application/ld+json; charset=utf-8",
        "Cache-Control": "public, max-age=86400"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
