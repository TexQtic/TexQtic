    "/api/control/trades": {
      "get": {
        "summary": "List trades (admin, cross-tenant, read-only)",
        "description": "Returns platform trades across all tenants. Optional query filters: tenantId, status, limit, offset. D-017-A: tenantId is an admin filter on the server query — never a client-supplied tenant identity in a request body. TECS-FBW-002-A (2026-03-07).",
        "parameters": [
          {
            "name": "tenantId",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Admin filter — restrict results to one tenant (D-017-A: admin query param only)"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["DRAFT", "ACTIVE", "SETTLED", "DISPUTED", "CANCELLED"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          }
        ],
        "responses": {
          "200": { "description": "Trade list returned successfully" },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/control/escalations": {
      "get": {
        "summary": "List G-022 escalation events for an org (admin cross-org read, read-only)",
        "description": "Returns escalation_events rows for the specified org. orgId is MANDATORY — API returns 400 if absent. Optional filters: entityType, entityId, status, limit. D-022-C: freezeRecommendation is informational only; no kill-switch side-effects. TECS-FBW-006-A (2026-03-11).",
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Target organisation ID (mandatory) — admin cross-org read boundary"
          },
          {
            "name": "entityType",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "entityId",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["OPEN", "RESOLVED", "OVERRIDDEN"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Escalation list returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "escalations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid" },
                          "orgId": { "type": "string", "format": "uuid" },
                          "entityType": { "type": "string" },
                          "entityId": { "type": "string", "format": "uuid" },
                          "parentEscalationId": {
                            "type": "string",
                            "format": "uuid",
                            "nullable": true
                          },
                          "source": { "type": "string" },
                          "severityLevel": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 4
                          },
                          "freezeRecommendation": { "type": "boolean" },
                          "triggeredByActorType": { "type": "string" },
                          "triggeredByPrincipal": { "type": "string" },
                          "reason": { "type": "string" },
                          "status": {
                            "type": "string",
                            "enum": ["OPEN", "RESOLVED", "OVERRIDDEN"]
                          },
                          "resolvedByPrincipal": {
                            "type": "string",
                            "nullable": true
                          },
                          "resolutionReason": {
                            "type": "string",
                            "nullable": true
                          },
                          "resolvedAt": {
                            "type": "string",
                            "format": "date-time",
                            "nullable": true
                          },
                          "createdAt": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    },
                    "count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request — orgId missing or invalid",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/control/certifications": {
      "get": {
        "summary": "List certifications across tenants (admin read-only — D-022-C)",
        "tags": ["Control Plane - Certifications"],
        "parameters": [
          {
            "in": "query",
            "name": "orgId",
            "schema": { "type": "string", "format": "uuid" }
          },
          { "in": "query", "name": "stateKey", "schema": { "type": "string" } },
          { "in": "query", "name": "limit", "schema": { "type": "integer" } },
          { "in": "query", "name": "offset", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Cross-tenant certification list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "certifications": {
                      "type": "array",
                      "items": { "type": "object" }
                    },
                    "count": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "UNAUTHORIZED" },
          "403": { "description": "FORBIDDEN" }
        }
      }
    },
    "/api/control/certifications/{id}": {
      "get": {
        "summary": "Get single certification by ID (admin read-only — D-022-C)",
        "tags": ["Control Plane - Certifications"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Admin certification detail including isTerminal flag",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "certification": {
                      "type": "object",
                      "properties": {
                        "certificationId": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "orgId": { "type": "string", "format": "uuid" },
                        "certificationType": { "type": "string" },
                        "stateKey": { "type": "string" },
                        "isTerminal": { "type": "boolean" },
                        "reason": { "type": "string" },
                        "issuedAt": {
                          "type": "string",
                          "format": "date-time",
                          "nullable": true
                        },
                        "expiresAt": {
                          "type": "string",
                          "format": "date-time",
                          "nullable": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "UNAUTHORIZED" },
          "403": { "description": "FORBIDDEN" },
          "404": { "description": "NOT_FOUND" }
        }
      }
    }
  }
}
