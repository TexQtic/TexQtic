/// G-028 Phase A1: Vector embeddings storage for semantic search and RAG.
/// One row per document chunk, strictly scoped to one org via FORCE RLS.
/// embedding dimension is LOCKED at 768 (text-embedding-004 / nomic-embed-text parity).
/// ⚠️ Changing dim requires DROP column + recreate + full reindex of all tenant data.
/// All similarity queries MUST use $queryRaw — Prisma does not support the <=> operator.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DocumentEmbedding {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// RLS boundary: scopes row to one organization. FK to organizations(id).
  orgId       String                @map("org_id") @db.Uuid
  /// Source entity type — e.g. 'CATALOG_ITEM' | 'DPP_SNAPSHOT' | 'CERTIFICATION'.
  /// Enforced by service layer; no DB enum to allow evolution without migrations.
  sourceType  String                @map("source_type")
  /// UUID of the originating entity in its domain table.
  sourceId    String                @map("source_id") @db.Uuid
  /// Sequential chunk index within the source entity (0-indexed).
  chunkIndex  Int                   @default(0) @map("chunk_index")
  /// Full text of the chunk (for audit/debug; may be truncated in A2).
  content     String
  /// Fingerprint of content for deduplication and idempotent upsert key.
  contentHash String                @map("content_hash")
  /// pgvector 768-dim embedding — LOCKED dimension.
  /// Prisma treats this as opaque (Unsupported). All similarity queries via $queryRaw.
  /// See server/src/lib/vectorQuery.ts (OPS-G028-A2-TVS-MODULE).
  embedding   Unsupported("vector")
  /// Per-chunk JSONB metadata bag (source version, language, model, indexed_at).
  metadata    Json                  @default("{}")
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  org         organizations         @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "document_embeddings_org_id_fk")

  @@unique([orgId, sourceType, sourceId, chunkIndex, contentHash], map: "document_embeddings_uq")
  @@index([orgId, sourceType, sourceId], map: "idx_doc_embed_org_source")
  @@index([contentHash], map: "idx_doc_embed_content_hash")
  @@index([embedding], map: "idx_doc_embed_hnsw")
  @@map("document_embeddings")
}

