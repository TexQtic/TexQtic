/// G-021 §3.A: Pending Maker–Checker approval request.
/// Created when StateMachineService.transition() returns PENDING_APPROVAL.
/// D-021-A: frozen_payload_hash enforces replay integrity (SHA-256 hex, len=64).
/// D-021-B: partial unique index enforces one active request per entity+transition.
/// D-021-C: maker_principal_fingerprint enables DB trigger to enforce Maker≠Checker.
/// MUTABLE on status only — all Maker identity/payload fields are frozen at insert.
model PendingApproval {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId                     String              @map("org_id") @db.Uuid
  entityType                String              @map("entity_type")
  entityId                  String              @map("entity_id") @db.Uuid
  fromStateKey              String              @map("from_state_key")
  toStateKey                String              @map("to_state_key")
  requestedByUserId         String?             @map("requested_by_user_id") @db.Uuid
  requestedByAdminId        String?             @map("requested_by_admin_id") @db.Uuid
  requestedByActorType      String              @map("requested_by_actor_type")
  requestedByRole           String              @map("requested_by_role")
  requestReason             String              @map("request_reason")
  frozenPayload             Json                @map("frozen_payload")
  /// D-021-A: SHA-256 hex (64 chars) over canonical transition fields.
  frozenPayloadHash         String              @map("frozen_payload_hash")
  /// D-021-C: "{requestedByActorType}:{requestedByUserId|requestedByAdminId}"
  makerPrincipalFingerprint String              @map("maker_principal_fingerprint")
  status                    String              @default("REQUESTED")
  attemptCount              Int                 @default(1) @map("attempt_count")
  expiresAt                 DateTime            @map("expires_at") @db.Timestamptz(6)
  /// Soft reference to G-022 escalation_records (no FK until escalation_records exists).
  escalationId              String?             @map("escalation_id") @db.Uuid
  aiTriggered               Boolean             @default(false) @map("ai_triggered")
  impersonationId           String?             @map("impersonation_id") @db.Uuid
  requestId                 String?             @map("request_id")
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  signatures                ApprovalSignature[]
  organizations             organizations       @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "pending_approvals_org_id_fk")

  @@index([orgId, entityType, entityId], map: "idx_pending_approvals_org_entity")
  @@index([orgId], map: "idx_pending_approvals_org_id")
  @@index([orgId, status], map: "idx_pending_approvals_org_status")
  @@map("pending_approvals")
}

/// G-021 §3.B: Append-only Checker decision record.
/// ALL columns are immutable after insert.
/// Layer 2: DB trigger prevent_approval_signature_modification raises P0001 on UPDATE/DELETE.
/// Layer 3: RLS UPDATE/DELETE policies USING false.
/// D-021-C: DB trigger check_maker_checker_separation fires on INSERT (AFTER).
/// signer_actor_type CHECK: IN ('CHECKER','PLATFORM_ADMIN') — no SYSTEM_AUTOMATION.
model ApprovalSignature {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  approvalId      String          @map("approval_id") @db.Uuid
  orgId           String          @map("org_id") @db.Uuid
  signerUserId    String?         @map("signer_user_id") @db.Uuid
  signerAdminId   String?         @map("signer_admin_id") @db.Uuid
  signerActorType String          @map("signer_actor_type")
  signerRole      String          @map("signer_role")
  decision        String
  reason          String
  impersonationId String?         @map("impersonation_id") @db.Uuid
  /// No updated_at — this table is append-only with zero mutable columns.
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  approval        PendingApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "approval_signatures_approval_id_fk")

  @@index([approvalId], map: "idx_approval_signatures_approval_id")
  @@index([orgId], map: "idx_approval_signatures_org_id")
  @@map("approval_signatures")
}

/// G-022: Append-only governance escalation record.
/// Covers entity-level (TRADE/ESCROW/APPROVAL/LIFECYCLE_LOG),
/// org-level (ORG — D-022-B), and global (GLOBAL — D-022-C) events.
///
/// D-022-A: parent_escalation_id enables a strictly monotonic severity upgrade chain.
/// Trigger trg_escalation_severity_upgrade enforces: new.severity > parent.severity
/// and parent.status = 'OPEN'. No UPDATE ever permitted.
///
/// D-022-B: Org-level freeze is stored as entity_type='ORG', entity_id=org_id,
/// severity_level >= 3, status='OPEN'. NO boolean column on organizations.
///
/// D-022-C: freeze_recommendation=true on GLOBAL rows is informational only.
/// EscalationService sets this flag; NO automated system reads it to toggle config.
///
/// Three-layer immutability:
/// Layer 1: EscalationService exposes no update/delete methods
/// Layer 2: DB trigger trg_escalation_events_immutability raises [E-022-IMMUTABLE]
/// Layer 3: RLS — no UPDATE or DELETE policy defined on this table
model EscalationEvent {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Live FK → organizations.id (G-015). RLS boundary.
  /// For entity_type='GLOBAL': platform-level sentinel org UUID.
  orgId                String            @map("org_id") @db.Uuid
  /// Domain scope: TRADE | ESCROW | APPROVAL | LIFECYCLE_LOG | ORG | GLOBAL
  /// DB CHECK constraint enforces this set.
  entityType           String            @map("entity_type")
  /// UUID of the escalated entity.
  /// For entity_type='ORG': equals org_id (D-022-B).
  /// For entity_type='GLOBAL': sentinel constant UUID.
  entityId             String            @map("entity_id") @db.Uuid
  /// D-022-A: NULL for root escalation. Set to prior row's id when upgrading severity.
  /// DB trigger ensures new.severity_level > parent.severity_level (strictly monotonic).
  parentEscalationId   String?           @map("parent_escalation_id") @db.Uuid
  /// EVENT SOURCE: STATE_MACHINE | APPROVAL | MANUAL | SYSTEM
  source               String
  /// SEVERITY: 0=Informational 1=Review 2=HighRisk 3=Critical 4=PlatformFreezeCandidate
  /// DB CHECK: IN (0,1,2,3,4)
  severityLevel        Int               @map("severity_level")
  /// D-022-C: Informational flag only. True on GLOBAL LEVEL_4 rows.
  /// Reading this flag NEVER triggers config changes automatically.
  freezeRecommendation Boolean           @default(false) @map("freeze_recommendation")
  /// ACTOR TYPE: PLATFORM_ADMIN | TENANT_ADMIN | SYSTEM_AUTOMATION | SERVICE_LAYER
  triggeredByActorType String            @map("triggered_by_actor_type")
  /// sub/fingerprint of the initiating actor (non-null, non-empty)
  triggeredByPrincipal String            @map("triggered_by_principal")
  /// Mandatory justification. Non-empty enforced by DB CHECK.
  reason               String
  /// STATUS: OPEN | RESOLVED | OVERRIDDEN
  /// Transitions: OPEN → RESOLVED or OPEN → OVERRIDDEN. Never reversed.
  /// No UPDATE permitted — status is immutable once written.
  status               String            @default("OPEN")
  /// NULL until resolved. Must be non-null when status != 'OPEN'.
  resolvedByPrincipal  String?           @map("resolved_by_principal")
  resolutionReason     String?           @map("resolution_reason")
  resolvedAt           DateTime?         @map("resolved_at") @db.Timestamptz(6)
  /// Wall-clock timestamp set by DB at commit time — not caller-supplied.
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  organizations        organizations     @relation(fields: [orgId], references: [id], onUpdate: NoAction)
  parent               EscalationEvent?  @relation("EscalationUpgradeChain", fields: [parentEscalationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  children             EscalationEvent[] @relation("EscalationUpgradeChain")
  sanctions            Sanction[]

  @@index([entityType, entityId, status, severityLevel], map: "escalation_events_entity_freeze_idx")
  @@index([orgId, createdAt(sort: Desc)], map: "escalation_events_org_id_idx")
  @@map("escalation_events")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// G-017 Day 1: Canonical trade entity.
/// Lifecycle-aligned (FK → lifecycle_states), tenant-scoped (FK → tenants),
/// escalation-compatible (freeze_recommended), reasoning-linked (reasoning_log_id → reasoning_logs).
/// No escrow FK in Day 1 — deferred to G-018.
/// RLS: RESTRICTIVE guard + PERMISSIVE SELECT/INSERT for texqtic_app.
/// No superadmin policy in Day 1 — deferred.
model Trade {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  buyerOrgId        String           @map("buyer_org_id") @db.Uuid
  sellerOrgId       String           @map("seller_org_id") @db.Uuid
  /// TECS-EXC-003: Optional source RFQ link for bounded RFQ-derived trade conversion.
  sourceRfqId       String?          @unique(map: "trades_source_rfq_id_key") @map("source_rfq_id") @db.Uuid
  /// G-020: Current lifecycle state. Reuses lifecycle_states registry.
  lifecycleStateId  String           @map("lifecycle_state_id") @db.Uuid
  /// Human-readable external reference. Unique per tenant.
  tradeReference    String           @map("trade_reference")
  currency          String
  /// DB CHECK: gross_amount > 0
  grossAmount       Decimal          @map("gross_amount") @db.Decimal(18, 6)
  /// G-022 compatibility: informational flag. Never auto-toggles any config (D-022-C).
  freezeRecommended Boolean          @default(false) @map("freeze_recommended")
  /// G-023: optional link to the reasoning_logs row that informed this trade.
  /// ON DELETE RESTRICT — reasoning_logs is immutable anyway.
  reasoningLogId    String?          @map("reasoning_log_id") @db.Uuid
  createdByUserId   String?          @map("created_by_user_id") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Maintained by DB trigger trg_trades_set_updated_at on BEFORE UPDATE.
  updatedAt         DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  escrow_id         String?          @db.Uuid
  events            TradeEvent[]
  buyerOrg          organizations    @relation("TradeBuyer", fields: [buyerOrgId], references: [id], onUpdate: NoAction, map: "fk_trades_buyer_org_id")
  sellerOrg         organizations    @relation("TradeSeller", fields: [sellerOrgId], references: [id], onUpdate: NoAction, map: "fk_trades_seller_org_id")
  sourceRfq         Rfq?             @relation("trade_source_rfq", fields: [sourceRfqId], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "trades_source_rfq_id_fk")
  escrow_accounts   escrow_accounts? @relation(fields: [escrow_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "trades_escrow_id_fk")
  lifecycleState    LifecycleState   @relation(fields: [lifecycleStateId], references: [id], onUpdate: NoAction)
  reasoningLog      ReasoningLog?    @relation(fields: [reasoningLogId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onUpdate: NoAction)

  @@unique([tenantId, tradeReference], map: "trades_tenant_ref_unique")
  @@index([tenantId])
  @@index([buyerOrgId])
  @@index([sellerOrgId])
  @@index([lifecycleStateId])
  @@map("trades")
}

/// G-017 Day 1: Append-only event log for a trade.
/// tenant_id is a plain column (no FK to tenants) — scoped via RLS only.
/// trade_id → trades(id) ON DELETE CASCADE.
/// No UPDATE/DELETE policies defined — append-only by design.
model TradeEvent {
