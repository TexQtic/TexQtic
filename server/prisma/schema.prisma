/// G-019: Certifications domain.
/// org_id → organizations(id) (canonical cross-plane entity).
/// lifecycle_state_id → lifecycle_states(id) (entity_type='CERTIFICATION').
/// RLS: RESTRICTIVE guard (incl. admin pass-through) + PERMISSIVE tenant/admin policies.
/// No DELETE — use lifecycle transitions to REVOKED/EXPIRED instead.
model Certification {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// RLS boundary: scopes row to one organization. FK to organizations(id).
  orgId               String                @map("org_id") @db.Uuid
  /// Open-coded cert category text (GOTS, OEKO_TEX, ISO_9001, ...). Not an enum.
  certificationType   String                @map("certification_type")
  /// G-020: Current lifecycle state (entity_type='CERTIFICATION').
  lifecycleStateId    String                @map("lifecycle_state_id") @db.Uuid
  /// Nullable: not set at SUBMITTED/UNDER_REVIEW; set on APPROVED.
  issuedAt            DateTime?             @map("issued_at") @db.Timestamptz(6)
  /// Nullable: some certifications do not expire.
  expiresAt           DateTime?             @map("expires_at") @db.Timestamptz(6)
  createdByUserId     String?               @map("created_by_user_id") @db.Uuid
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  /// Maintained by DB trigger trg_certifications_set_updated_at on BEFORE UPDATE.
  updatedAt           DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  certification_lifecycle_logs CertificationLifecycleLog[]
  lifecycleState      LifecycleState        @relation(fields: [lifecycleStateId], references: [id], onUpdate: NoAction)
  org                 organizations         @relation(fields: [orgId], references: [id], onUpdate: NoAction)
