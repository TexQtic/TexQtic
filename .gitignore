
# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/

# Production
dist/
build/

# Misc
.DS_Store
*.pem

# Environment Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backups (never commit backup files — may contain secrets)
*.bak

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server-smoke*.log

# Database
*.db
*.db-journal

# Prisma
# NOTE: Migrations MUST be tracked in version control (governance requirement)
# Excluding migrations causes DB↔git drift and breaks reproducibility
# All migration files in server/prisma/migrations/ are now tracked

# SonarLint / SonarQube
.sonarlint/
.scannerwork/
.sonarqube/

# Local validation tooling (do not commit)
server/scripts/proof-*.ts

# Local archive/transport artifacts (never commit)
*.zip

# CI guard runtime output (generated by scripts/control-plane-guard.ts — never commit)
artifacts/

# Debug / test-run output files (never commit — use logs, not files)
server/*.txt
server/*.json.bak

.vercel
.env*.local
